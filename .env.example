# Copie para .env e preencha. O .env é git-ignored.
# Pegue uma chave em https://openrouter.ai/keys
OPENROUTER_API_KEY=

# DICA (uso global): em vez de editar este arquivo, rode `ncrawl key set <chave>` — ele valida a
# chave na OpenRouter e a grava em ~/.newsletter-crawler/.env (NC_HOME), que tem precedência final.

# Opcionais (defaults entre parênteses):
# NC_HOME=~/.newsletter-crawler  # "casa" dos dados do usuário (banco, .env, sources.json, export/)
# LLM_PRO_MODEL=deepseek/deepseek-v4-pro
# LLM_FLASH_MODEL=deepseek/deepseek-v4-flash
# CRAWLER_UA=NewsletterArchiver/1.0 (+https://example.com/bot; contato: you@example.com)
# OPENROUTER_REFERER=https://example.com
# CONCURRENCY=0        # 0/ausente = governador decide; >0 = teto duro do loop do crawl
# PER_HOST_CONCURRENCY=2
# REQUEST_DELAY_MS=1000
# MAX_RETRIES=3
# MAX_HTML_FOR_LLM=120000
# CRAWLER_RESPECT_ROBOTS=true
# DB_PATH=crawler.db   # relativo resolve contra NC_HOME (default ~/.newsletter-crawler/crawler.db)

# Renderização (Playwright/chromium): em container o chromium aborta sem --no-sandbox.
# CRAWLER_CHROMIUM_ARGS=--no-sandbox,--disable-dev-shm-usage,--disable-gpu

# Crawl multinível (índice -> roundup/issue -> artigo) e detecção de roundup:
# MAX_CRAWL_DEPTH=3
# ROUNDUP_MIN_LINKS=3            # mín. de links externos p/ uma issue/roundup valer
# ARTICLE_ROUNDUP_MIN_LINKS=10   # divide um "artigo" em N só se for lista de links...
# ARTICLE_ROUNDUP_MAX_LINKS=60   # ...e não um link-farm/lista de referências...
# ROUNDUP_MAX_PROSE_CHARS=1500   # ...e com pouca prosa (paper longo NÃO é roundup)
# SINCE_MAX_INDEX_PAGES=60       # teto de páginas do índice quando --since está ativo

# Resumos PT-BR e busca:
# SUMMARIZE_AFTER_CRAWL=true     # gera resumos PT-BR ao fim do crawl (=false desliga)
# SUMMARIZE_CONCURRENCY=0        # 0 = lane llm do governador decide; >0 = teto duro
# SUMMARIZE_MAX_CHARS=12000
# SEARCH_FLASH_CONCURRENCY=0     # modo A: 0 = lane llm decide; >0 = teto duro
# SEARCH_MAX_CHARS=8000          # recorte por artigo no modo A
# SEARCH_MODE_A_CONFIRM=200      # acima disto, o modo A exige --yes

# Paralelismo global + orçamento (governador de RAM + ledger de custo):
# MAX_PARALLEL=0        # teto GLOBAL de operações simultâneas (0 = nº de núcleos, clamp 4..64)
# BUDGET_USD=0          # orçamento por execução em USD (0 = ilimitado; o custo é registrado sempre)
# RAM_MAX_PCT=80        # teto de uso de RAM DO SISTEMA (MemAvailable >= max(total*20%, 2 GiB))
# RAM_HYSTERESIS_PCT=10 # banda morta acima do piso antes de voltar a crescer
# GOVERNOR_TICK_MS=1000 # período do laço AIMD do governador
# RENDER_EST_MB=300     # estimativa de RAM por contexto Chromium (ramp da lane render)
# LLM_TIMEOUT_MS=180000 # timeout por chamada LLM (SDK: maxRetries=1)
# CLASSIFY_CONCURRENCY=0  # facetas simultâneas (0 = lane llm decide)
# ARTICLE_CONCURRENCY=0   # artigos classificados em paralelo (0 = lane llm decide)

# DEBUG=1   # logs verbosos (decisões de fetch, depth, contagem de links) no stderr
