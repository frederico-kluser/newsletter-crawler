#!/usr/bin/env bash
# Garante que o snapshot do webapp (webapp/public/data) reflete o SQLite local antes de todo
# push na main — a Vercel (Git integration, Root Directory webapp/) publica o que estiver
# commitado. Instalado por `npm install` (postinstall → git config core.hooksPath .githooks).
#
# Fail-open por design (o hook nunca pode travar trabalho legítimo):
#   • push sem a main (ou deleção de ref) → não faz nada;
#   • export falhou (máquina sem node/dependências) → avisa e o push segue;
#   • snapshot novo MENOR que o commitado → restaura e o push segue SEM commit (máquina sem o
#     banco real exporta um acervo vazio — jamais auto-publicar isso; pós-purge intencional,
#     exporte e commite manualmente);
#   • só a linha volátil `generatedAt` do meta.json mudou → restaura e o push segue;
#   • dado novo de verdade → commita webapp/public/data + webapp/public/api/v1 e ABORTA o push
#     (um commit criado durante o push não entra nele): repita o `git push`.
#
# O mesmo `export --format web` regenera a API pública em webapp/public/api/v1/corpus.json — ela
# viaja junto do snapshot em todos os ramos abaixo (encolheu → restaura; só generatedAt → restaura;
# dado novo → commita), pelos MESMOS guards.
set -u

DATA_DIR="webapp/public/data"
API_DIR="webapp/public/api/v1"
META="$DATA_DIR/meta.json"
CORPUS="$API_DIR/corpus.json"
ZERO="0000000000000000000000000000000000000000"

# stdin do pre-push: "<local ref> <local sha> <remote ref> <remote sha>" por ref pushado.
pushing_main=0
while read -r _local_ref local_sha remote_ref _remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ] && [ "$local_sha" != "$ZERO" ]; then
    pushing_main=1
  fi
done
[ "$pushing_main" = "1" ] || exit 0

cd "$(git rev-parse --show-toplevel)" || exit 0

echo "[pre-push] re-exportando o snapshot do webapp a partir do banco local…"
if ! node --env-file-if-exists=.env src/index.js export --format web; then
  echo "[pre-push] aviso: export falhou (sem banco/node aqui?) — push segue com o snapshot commitado." >&2
  exit 0
fi

# Totais p/ o guard anti-encolhimento (vazio se não der pra ler — aí o guard não se aplica).
total_novo=$(node -p "require('./$META').totals.articles" 2>/dev/null)
total_head=$(git show "HEAD:$META" 2>/dev/null | node -p "JSON.parse(require('node:fs').readFileSync(0,'utf8')).totals.articles" 2>/dev/null)
case "$total_novo" in '' | *[!0-9]*) total_novo="" ;; esac
case "$total_head" in '' | *[!0-9]*) total_head="" ;; esac

if [ -n "$total_novo" ] && [ -n "$total_head" ] && [ "$total_novo" -lt "$total_head" ]; then
  git restore -- "$DATA_DIR" "$API_DIR" 2>/dev/null || git checkout -- "$DATA_DIR" "$API_DIR"
  echo "[pre-push] aviso: snapshot novo tem MENOS artigos ($total_novo < $total_head) — máquina sem o banco real?" >&2
  echo "[pre-push] nada foi commitado; se a redução é intencional (purge), rode e commite manualmente: ncrawl export --format web" >&2
  exit 0
fi

# Mudança real = articles/contents diferentes de HEAD, ou meta.json ignorando o generatedAt
# (indent 1 do export = um campo por linha, então o grep -v tira só essa linha).
real_change=0
if ! git diff --quiet HEAD -- "$DATA_DIR/articles.json" "$DATA_DIR/contents.json" 2>/dev/null; then
  real_change=1
elif ! diff -q <(git show "HEAD:$META" 2>/dev/null | grep -v '"generatedAt"') \
  <(grep -v '"generatedAt"' "$META") >/dev/null 2>&1; then
  real_change=1
elif ! diff -q <(git show "HEAD:$CORPUS" 2>/dev/null | grep -v '"generatedAt"') \
  <(grep -v '"generatedAt"' "$CORPUS") >/dev/null 2>&1; then
  real_change=1
fi

if [ "$real_change" = "0" ]; then
  git restore -- "$META" "$CORPUS" 2>/dev/null || git checkout -- "$META" "$CORPUS"
  echo "[pre-push] snapshot já em dia (${total_head:-?} artigos) — push segue."
  exit 0
fi

git add -- "$DATA_DIR" "$API_DIR"
if ! git commit --no-verify -m "chore(data): atualiza snapshot do webapp + API pública (pre-push, ${total_novo:-?} artigos)" -- "$DATA_DIR" "$API_DIR"; then
  echo "[pre-push] aviso: commit do snapshot falhou — push segue sem ele." >&2
  exit 0
fi
echo ""
echo "[pre-push] o banco local tinha dado novo: snapshot exportado e commitado (${total_head:-?} → ${total_novo:-?} artigos)."
echo "[pre-push] este push foi INTERROMPIDO de propósito — um commit criado durante o push não entra nele."
echo "[pre-push] rode 'git push' de novo para publicar tudo (a Vercel faz o deploy sozinha)."
exit 1
