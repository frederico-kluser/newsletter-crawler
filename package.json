{
  "name": "newsletter-crawler",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Crawler de newsletters em Node.js puro com seletores CSS gerados por LLM (OpenRouter / DeepSeek V4) e cache self-healing em SQLite.",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "ncrawl": "src/index.js",
    "newsletter-crawler": "src/index.js"
  },
  "scripts": {
    "crawl": "node --env-file-if-exists=.env src/index.js crawl",
    "status": "node --env-file-if-exists=.env src/index.js status",
    "inspect": "node --env-file-if-exists=.env src/index.js inspect",
    "verify": "node --env-file-if-exists=.env src/index.js verify",
    "purge": "node --env-file-if-exists=.env src/index.js purge",
    "add": "node --env-file-if-exists=.env src/index.js add",
    "export": "node --env-file-if-exists=.env src/index.js export",
    "classify": "node --env-file-if-exists=.env src/index.js classify",
    "summarize": "node --env-file-if-exists=.env src/index.js summarize",
    "finish": "node --env-file-if-exists=.env src/index.js finish",
    "search": "node --env-file-if-exists=.env src/index.js search",
    "web": "node --env-file-if-exists=.env src/index.js web",
    "key": "node src/index.js key",
    "limits": "node --env-file-if-exists=.env src/index.js limits",
    "reset": "node --env-file-if-exists=.env src/index.js reset",
    "test": "node --test",
    "ui": "NODE_NO_WARNINGS=1 node --env-file-if-exists=.env src/index.js ui",
    "menu": "NODE_NO_WARNINGS=1 node --env-file-if-exists=.env src/index.js menu",
    "start": "node --env-file-if-exists=.env src/index.js",
    "link": "npm install && npx playwright install chromium && npm link && node src/index.js status",
    "unlink": "npm rm -g newsletter-crawler"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "got": "^15.0.7",
    "htm": "^3.1.1",
    "ink": "^5.2.1",
    "jsdom": "^29.1.1",
    "normalize-url": "^9.0.1",
    "openai": "^6.45.0",
    "p-limit": "^7.3.0",
    "playwright": "^1.61.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "robots-parser": "^3.0.1",
    "turndown": "^7.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "ink-testing-library": "^4.0.0"
  }
}
